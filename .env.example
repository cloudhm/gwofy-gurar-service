# 复制为 .env.local 后填写；勿提交含真实值的文件。
# 加载：set -a && source .env.local && set +a

# AWS（部署到香港示例）
export AWS_REGION=ap-east-1
export AWS_DEFAULT_REGION=ap-east-1
# export AWS_PROFILE=gwofy-hk

# Shopify（CDK 会写入 Lambda）
export SHOPIFY_CLIENT_ID=
export SHOPIFY_CLIENT_SECRET=
# 可选；默认与代码一致为 2026-04（Admin GraphQL / webhook 配置）
# export SHOPIFY_API_VERSION=2026-04
# Theme editor deep link (GET /api/me embed_deep_link); appEmbed query value
# export SHOPIFY_THEME_APP_EMBED=9b094559e27d2b0b68a5c0c0b4743f73/insurance
# export SHOPIFY_THEME_EMBED_PREVIEW_PATH=/cart

# 已有 Cognito：/admin JWT（合成与部署 Api 栈前必填 User Pool）
export ADMIN_COGNITO_USER_POOL_ID=
# 可选；省略时由 Custom Resource 在 Pool 内创建或复用名为 GWO-SHIPPING-PROTECTION 的 App Client
export ADMIN_COGNITO_CLIENT_ID=
# 可选；同一 User Pool 下额外允许的 App Client（逗号或空格分隔），JWT aud 匹配其一即可
# 若未设 ADMIN_COGNITO_CLIENT_ID，须在此列出全部允许的 Client（含 GWO-SHIPPING-PROTECTION）
# export ADMIN_COGNITO_CLIENT_IDS=other-client-id-1,other-client-id-2
# 若 User Pool 不在 Api 栈所在区域，填写该区域，否则可省略（默认与栈同区）
# export ADMIN_COGNITO_REGION=ap-east-1

# Cognito Hosted UI：`GET /auth/callback` 换 token 时需要（示例为前缀域名，无 https）
# export COGNITO_HOSTED_UI_DOMAIN=ap-east-1xxxx.auth.ap-east-1.amazoncognito.com

# 自定义域名：ACM 证书须与 API 同区域（香港即 ap-east-1）
export GWOFY_API_CERTIFICATE_ARN=

# 可选：Route 53 托管域名 ``gwofy.com`` 时，同时设置下列两项可在部署时自动创建指向 API Gateway 的别名 A 记录（否则请手工 CNAME，见 README）
# export GWOFY_ROUTE53_HOSTED_ZONE_ID=Zxxxxxxxxxxxx
# export GWOFY_ROUTE53_ZONE_NAME=gwofy.com

# 可选
# export POST_INSTALL_REDIRECT_URL=
# export FEISHU_WEBHOOK_URL=
# export WEBHOOK_BASE_URL=
# 写入 Dynamo 订单镜像 sync_tags（不在商户 Shopify 订单上打标）；GET /admin/.../orders?tag= 可按此过滤
# export ORDER_PROTECTION_TAG=gwofy-shipping-protection
# export ADMIN_COGNITO_GROUP=GWOFY-SHIPPING-PROTECTION
